{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agent-foo-cf",
  "compatibility_date": "2026-04-05",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "main": "./worker/index.ts",
  "assets": {
    "directory": "dist/client",
    "not_found_handling": "none",
    "binding": "ASSETS"
  },
  "images": {
    "binding": "IMAGES"
  },
  "durable_objects": {
    "bindings": [
      { "name": "PLAN_SESSION", "class_name": "PlanSession" },
      { "name": "MCP_SESSION", "class_name": "McpSession" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["PlanSession"] },
    { "tag": "v2", "new_classes": ["McpSession"] }
  ]
}
